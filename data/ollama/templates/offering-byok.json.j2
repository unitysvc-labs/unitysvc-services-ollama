{
  "schema": "offering_v1",
  "name": "{{ offering_name }}",
  "display_name": "{{ display_name }}",
  "description": {{ description | tojson }},
  "service_type": "{{ service_type }}",
  "status": "{{ status | default('ready') }}",
  "currency": "USD",
  "tags": {{ tags | tojson }},
{%- if capabilities %}
  "capabilities": {{ capabilities | tojson }},
{%- endif %}
  "details": {{ details | tojson }},
{#- Ollama Cloud's API lives directly on ``ollama.com`` (``/v1/chat/completions``
    for the OpenAI-compat surface, ``/api/chat`` for native).  The
    ``api.ollama.com`` host is a Cloudflare 301-redirect to ``ollama.com``,
    and HTTP clients strip the ``Authorization`` header on cross-origin
    redirects — so routing upstream through ``api.ollama.com`` produces a
    401 from the public landing site even with a valid key.  Always point
    at ``ollama.com`` directly. -#}
  "upstream_access_config": {
    "ollama_cloud_api": {
      "access_method": "http",
      "base_url": "https://ollama.com",
      "api_key": "${ customer_secrets.{{ env_api_key_name }} }",
      "rate_limits": [],
      "routing_key": {"model": "{{ routing_model | default(offering_name) }}"}
    }
  }
}
