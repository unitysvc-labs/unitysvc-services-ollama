{
  "schema": "listing_v1",
  "status": "{{ status | default('ready') }}",
  "currency": "USD",
  "user_access_interfaces": {
    "Ollama API": {
      "access_method": "http",
      "base_url": "${GATEWAY_BASE_URL}/p/{{ provider_name }}/{{ offering_name }}",
      "routing_key": {"model": "{{ offering_name }}"}
    }
  },
  "user_parameters_schema": {
    "type": "object",
    "title": "Ollama Endpoint Configuration",
    "description": "Provide the URL of your Ollama server",
    "required": ["base_url"],
    "properties": {
      "base_url": {
        "type": "string",
        "title": "Ollama Server URL",
        "default": "http://localhost:11434",
        "description": "Base URL of your Ollama server (e.g. http://localhost:11434 or http://your-server:11434)"
      },
      "api_key_secret": {
        "type": "string",
        "title": "API Key Secret",
        "default": "",
        "description": "Name of your stored secret containing the API key (leave empty if no auth needed)"
      }
    }
  },
  "user_parameters_ui_schema": {
    "base_url": {
      "ui:placeholder": "http://localhost:11434",
      "ui:description": "The base URL where your Ollama instance is running"
    },
    "api_key_secret": {
      "ui:widget": "secret-selector",
      "ui:description": "Select a secret from your secret store, or leave empty if your server requires no authentication"
    }
  },
  "service_options": {
    "ops_testing_parameters": {
      "base_url": "https://ollama.svcpass.com",
      "api_key_secret": ""
    }
  },
