{#- BYOE Ollama listing.  Two test postures:

    * ``is_installed`` true — the model has been pulled on the
      ops-test endpoint (``ollama.svcmarket.com``); CI can exercise the
      Python / JS / cURL code examples for real.  ``routing_model``
      points at the specific tag we pulled (e.g. ``qwen2.5:1.5b``)
      since the catalog name (``qwen2.5``) would otherwise resolve to
      ``:latest`` which we don't host.
    * ``is_installed`` false — code-example docs are rendered as
      reference material but marked ``test.status = skip`` so CI only
      runs the connectivity probe (which always runs and only checks
      the gateway can reach the upstream Ollama daemon).
-#}
{
  "schema": "listing_v1",
  "status": "{{ status | default('ready') }}",
  "currency": "USD",
  {#- name = <provider>/<bare> per the platform service-naming convention
      (unitysvc PR #1196 / issue #1138).  The gateway resolves the runtime
      ``service_name`` Jinja in base_url below to this exact string. #}
  "name": "{{ provider_name }}/{{ offering_name }}",
  "user_access_interfaces": {
    "ollama_api": {
      "access_method": "http",
      {#- {% raw %}/{% endraw %} keeps the runtime ``{{ service_name }}`` Jinja
          intact across this generator's render pass. #}
      "base_url": "${API_GATEWAY_BASE_URL}/{% raw %}{{ service_name }}{% endraw %}",
      "routing_key": {"model": "{{ routing_model | default(offering_name) }}"}
    }
  },
  "user_parameters_schema": {
    "type": "object",
    "title": "Ollama Endpoint Configuration",
    "description": "Provide the URL of your Ollama server",
    "required": ["base_url"],
    "properties": {
      "base_url": {
        "type": "string",
        "title": "Ollama Server URL",
        "default": "http://localhost:11434",
        "description": "Base URL of your Ollama server (e.g. http://localhost:11434 or http://your-server:11434)"
      },
      "api_key_secret": {
        "type": "string",
        "title": "API Key Secret",
        "default": "",
        "description": "Name of your stored secret containing the API key (leave empty if no auth needed)"
      }
    }
  },
  "user_parameters_ui_schema": {
    "base_url": {
      "ui:placeholder": "http://localhost:11434",
      "ui:description": "The base URL where your Ollama instance is running"
    },
    "api_key_secret": {
      "ui:widget": "secret-selector",
      "ui:description": "Select a secret from your secret store, or leave empty if your server requires no authentication"
    }
  },
  "service_options": {
    "ops_testing_parameters": {
      "base_url": "https://ollama.svcmarket.com",
      "api_key_secret": ""
    }
  },
  "documents": {
    "How to use this model": {
      "category": "getting_started",
      "file_path": "../../docs/description-byoe.md",
      "is_active": true,
      "is_public": true,
      "mime_type": "markdown"
    },
    "Python code example": {
{%- if is_installed %}
      "$doc_preset": "llm_code_example_requests"
{%- else %}
      "$doc_preset": {
        "name": "llm_code_example_requests",
        "meta": {"test": {"status": "skip"}}
      }
{%- endif %}
    },
    "Python ollama-python code example": {
      "category": "code_example",
      "description": "Example code using the ollama-python library",
      "file_path": "../../docs/code-example-ollama.py.j2",
      "is_active": true,
      "is_public": true,
      "mime_type": "python"{% if not is_installed %},
      "meta": {"test": {"status": "skip"}}{% endif %}
    },
    "JavaScript code example": {
{%- if is_installed %}
      "$doc_preset": "llm_code_example_javascript"
{%- else %}
      "$doc_preset": {
        "name": "llm_code_example_javascript",
        "meta": {"test": {"status": "skip"}}
      }
{%- endif %}
    },
    "cURL code example": {
{%- if is_installed %}
      "$doc_preset": "llm_code_example_shell"
{%- else %}
      "$doc_preset": {
        "name": "llm_code_example_shell",
        "meta": {"test": {"status": "skip"}}
      }
{%- endif %}
    },
    "Connectivity test": {
      "$doc_preset": "api_connectivity"
    }
  }
}
