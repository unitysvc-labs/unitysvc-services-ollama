{
  "schema": "offering_v1",
  "name": "{{ offering_name }}",
  "display_name": "{{ display_name }}",
  "description": {{ description | tojson }},
  "service_type": "{{ service_type }}",
  "status": "{{ status | default('ready') }}",
  "currency": "USD",
  "tags": {{ tags | tojson }},
{%- if capabilities %}
  "capabilities": {{ capabilities | tojson }},
{%- endif %}
  "details": {{ details | tojson }},
  "upstream_access_config": {
    "Ollama API": {
      "access_method": "http",
      "base_url": "{% raw %}{{ base_url }}{% endraw %}",
      "api_key": "{% raw %}{% if api_key_secret %}${ customer_secrets.{{ api_key_secret }} }{% else %}{% endif %}{% endraw %}",
      "rate_limits": [],
      "routing_key": {"model": "{{ offering_name }}"}
    }
  }
}
