{
  "schema": "listing_v1",
  "status": "{{ status | default('ready') }}",
  "currency": "USD",
  {#- name = <provider>/<bare> per the platform service-naming convention
      (unitysvc PR #1196 / issue #1138).  The gateway resolves the runtime
      ``service_name`` Jinja in base_url below to this exact string. #}
  "name": "{{ provider_name }}/{{ offering_name }}",
  "user_access_interfaces": {
    "ollama_cloud_api": {
      "access_method": "http",
      {#- {% raw %}/{% endraw %} keeps the runtime ``{{ service_name }}`` Jinja
          intact across this generator's render pass. #}
      "base_url": "${API_GATEWAY_BASE_URL}/{% raw %}{{ service_name }}{% endraw %}",
      "routing_key": {"model": "{{ offering_name }}"}
    }
  },
  "documents": {
    "How to use this model": {
      "category": "getting_started",
      "file_path": "../../docs/description-byok.md",
      "is_active": true,
      "is_public": true,
      "mime_type": "markdown"
    },
    "Python code example": {
      "$doc_preset": "llm_code_example_requests"
    },
    "JavaScript code example": {
      "$doc_preset": "llm_code_example_javascript"
    },
    "cURL code example": {
      "$doc_preset": "llm_code_example_shell"
    },
    "Connectivity test": {
      "$doc_preset": "api_connectivity"
    }
  }
}
