{
  "schema": "listing_v1",
  "status": "{{ status | default('ready') }}",
  "currency": "USD",
  "user_access_interfaces": {
    "ollama_cloud_api": {
      "access_method": "http",
      "base_url": "${API_GATEWAY_BASE_URL}/p/{{ provider_name }}",
      "routing_key": {"model": "{{ offering_name }}"}
    }
  },
  "documents": {
    "How to use this model": {
      "category": "getting_started",
      "file_path": "../../docs/description-byok.md",
      "is_active": true,
      "is_public": true,
      "mime_type": "markdown"
    },
    "Python code example": {
      "$doc_preset": "llm_code_example_requests"
    },
    "Python ollama-python code example": {
      "category": "code_example",
      "description": "Example code using the ollama-python library",
      "file_path": "../../docs/code-example-ollama.py.j2",
      "is_active": true,
      "is_public": true,
      "mime_type": "python"
    },
    "JavaScript code example": {
      "$doc_preset": "llm_code_example_javascript"
    },
    "cURL code example": {
      "$doc_preset": "llm_code_example_shell"
    },
    "Connectivity test": {
      "$doc_preset": "api_connectivity"
    }
  }
}
