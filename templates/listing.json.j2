{
  "status": "{{ status | default('ready') }}",
  "currency": "USD",
  "name": "{{ provider_name }}/{{ offering_name }}",
  "list_price": {{ list_price | tojson }},
  "user_access_interfaces": {{ user_access_interfaces | tojson }},
  "user_parameters_schema": {
    "type": "object",
    "title": "Ollama Endpoint Configuration",
    "description": "Provide the URL of your Ollama server for the BYOE channel",
    "required": ["base_url"],
    "properties": {
      "base_url": {
        "type": "string",
        "title": "Ollama Server URL",
        "default": "http://localhost:11434",
        "description": "Base URL of your Ollama server (e.g. http://localhost:11434 or http://your-server:11434)"
      }
    }
  },
  "user_parameters_ui_schema": {
    "base_url": {
      "ui:placeholder": "http://localhost:11434",
      "ui:description": "The base URL where your Ollama instance is running"
    }
  },
  "service_options": {
    "ops_testing_parameters": {
      "base_url": "https://ollama.svcmarket.com"
    }
  },
  "documents": {
    "How to use this model with BYOE": {
      "category": "getting_started",
      "file_path": "description-byoe.md",
      "is_active": true,
      "is_public": true,
      "mime_type": "markdown"
    }{% if has_cloud %},
    "How to use this model with Ollama Cloud": {
      "category": "getting_started",
      "file_path": "description-cloud.md",
      "is_active": true,
      "is_public": true,
      "mime_type": "markdown"
    }{% endif %},
    "Python code example": {
{%- if is_installed %}
      "$doc_preset": "llm_code_example_requests"
{%- else %}
      "$doc_preset": {
        "name": "llm_code_example_requests",
        "meta": {"test": {"status": "skip"}}
      }
{%- endif %}
    },
    "Python ollama-python code example": {
      "category": "code_example",
      "description": "Example code using the ollama-python library",
      "file_path": "code-example-ollama.py.j2",
      "is_active": true,
      "is_public": true,
      "mime_type": "python"{% if not is_installed %},
      "meta": {"test": {"status": "skip"}}{% endif %}
    },
    "JavaScript code example": {
{%- if is_installed %}
      "$doc_preset": "llm_code_example_javascript"
{%- else %}
      "$doc_preset": {
        "name": "llm_code_example_javascript",
        "meta": {"test": {"status": "skip"}}
      }
{%- endif %}
    },
    "cURL code example": {
{%- if is_installed %}
      "$doc_preset": "llm_code_example_shell"
{%- else %}
      "$doc_preset": {
        "name": "llm_code_example_shell",
        "meta": {"test": {"status": "skip"}}
      }
{%- endif %}
    },
    "Connectivity test": {
      "$doc_preset": "api_connectivity"
    },
    "Default request body": {
      "$doc_preset": "llm_request_template"
    }
  }
}
