{
  "name": "{{ offering_name }}",
  "display_name": "{{ display_name }}",
  "description": {{ description | tojson }},
  "service_type": "{{ service_type }}",
  "status": "{{ status | default('ready') }}",
  "currency": "USD",
  "tags": {{ tags | tojson }},
{%- if capabilities %}
  "capabilities": {{ capabilities | tojson }},
{%- endif %}
  "details": {{ details | tojson }},
  "upstream_access_config": {
    "byoe": {
      "access_method": "http",
      "base_url": "{{ '{{ params.base_url }}' }}",
      "rate_limits": [],
      "routing_key": {
        "model": "{{ ops_testing_model }}"
      },
      "sort_order": 3
    }{% if in_ollama_cloud %},
    "managed": {
      "access_method": "http",
      "api_key": "${ secrets.OLLAMA_API_KEY }",
      "base_url": "https://ollama.com",
      "rate_limits": [],
      "routing_key": {
        "model": "{{ cloud_model }}"
      },
      "sort_order": 1
    },
    "byok": {
      "access_method": "http",
      "api_key": "${ customer_secrets.OLLAMA_API_KEY }",
      "base_url": "https://ollama.com",
      "rate_limits": [],
      "routing_key": {
        "model": "{{ cloud_model }}"
      },
      "sort_order": 2
    }{% endif %}
  }
}
